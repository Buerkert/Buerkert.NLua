<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <ReleaseVersion>1.3.2</ReleaseVersion>
    <TargetFramework>net45</TargetFramework>
    <AssemblyTitle>NLuaTest</AssemblyTitle>
    <Product>NLuaTest</Product>
    <Copyright>Copyright ©  2013</Copyright>
    <Configurations>Debug;Release</Configurations>
    <Platforms>AnyCPU;x86</Platforms>
  </PropertyGroup>
  <ItemGroup>
    <None Include="core\*.lua" CopyToOutputDirectory="PreserveNewest" />
    <None Include="scripts\*.lua*" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="NUnit" Version="3.12.0" />
    <PackageReference Include="NUnit.ConsoleRunner" Version="3.10.0" />
    <PackageReference Include="NUnit3TestAdapter" Version="3.16.0" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\NLua\NLua.csproj" />
  </ItemGroup>
</Project>